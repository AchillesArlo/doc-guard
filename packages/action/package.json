{
  "name": "@docs-guard/action",
  "version": "1.0.0",
  "description": "GitHub Action wrapper for Docs Guard",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/main.ts --format esm --dts"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@docs-guard/collectors": "workspace:*",
    "@docs-guard/core": "workspace:*",
    "@docs-guard/parsers": "workspace:*",
    "@docs-guard/project-analyzer": "workspace:*",
    "@docs-guard/checkers": "workspace:*",
    "@docs-guard/reporters": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
